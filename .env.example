DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js / NextAuth
# Lokal auf die echte Dev-URL anpassen, z.B. http://localhost:3000 oder http://localhost:3001
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
ADMIN_EMAILS="l.kraus@franco-consulting.com"

# AI
VANTERO_API_KEY="replace-with-vantero-api-key"
VANTERO_API_URL="https://api.vantero.de/v1"
VANTERO_MODEL="gpt-4o-mini"
VANTERO_TIMEOUT_MS="120000"

# Leads / E-Mail
RESEND_API_KEY="replace-with-resend-api-key"
LEADS_TO_EMAIL="kontakt@example.com"
LEADS_FROM_EMAIL="onboarding@resend.dev"

# Optional: Lokalen Browser für Puppeteer explizit setzen
# PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
